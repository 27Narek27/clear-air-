<?xml version="1.0" encoding="utf-8"?>

<full-backup-content>
    <!-- Исключаем всю базу данных Room -->
    <exclude domain="database" path="ecosys_database" />
    <exclude domain="database" path="ecosys_database-shm" />
    <exclude domain="database" path="ecosys_database-wal" />

    <!-- Исключаем токены и настройки аутентификации -->
    <exclude domain="sharedpref" path="auth_tokens.xml" />
    <exclude domain="sharedpref" path="user_session.xml" />

    <!-- DataStore файлы тоже не бэкапим -->
    <exclude domain="file" path="datastore/" />
</full-backup-content>