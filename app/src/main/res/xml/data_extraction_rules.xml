<?xml version="1.0" encoding="utf-8"?>

<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="ecosys_database" />
        <exclude domain="database" path="ecosys_database-shm" />
        <exclude domain="database" path="ecosys_database-wal" />
        <exclude domain="sharedpref" path="auth_tokens.xml" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>

    <device-transfer>
        <!-- При переносе на новое устройство бэкап разрешён,
             но токены сессии всё равно исключаем -->
        <include domain="database" path="ecosys_database" />
        <exclude domain="sharedpref" path="auth_tokens.xml" />
    </device-transfer>
</data-extraction-rules>